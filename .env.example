# GIMMES Configuration
# Copy to .env and fill in your values

# Mode: driving_range (demo/paper) or championship (production/real money)
GIMMES_MODE=driving_range

# Kalshi Demo API credentials (Driving Range)
KALSHI_DEMO_API_KEY=your-demo-api-key-uuid
KALSHI_DEMO_PRIVATE_KEY_PATH=~/.kalshi/demo_private.pem

# Kalshi Production API credentials (Championship) — optional
# KALSHI_PROD_API_KEY=your-prod-api-key-uuid
# KALSHI_PROD_PRIVATE_KEY_PATH=~/.kalshi/prod_private.pem
